{
  "name": "autoapply",
  "version": "1.9.0",
  "description": "AutoApply — Automated Job Application Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/sync-version.js && node scripts/bundle-python.js",
    "dist:win": "npm run prebuild && electron-builder --win",
    "dist:mac": "npm run prebuild && electron-builder --mac",
    "dist:linux": "npm run prebuild && electron-builder --linux",
    "dist:all": "npm run prebuild && electron-builder --win --mac --linux",
    "icons:generate": "node scripts/generate-icon.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AbhishekMandapmalvi/AutoApply.git"
  },
  "author": "AutoApply",
  "license": "MIT",
  "devDependencies": {
    "canvas": "^3.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "com.autoapply.desktop",
    "productName": "AutoApply",
    "directories": {
      "output": "build"
    },
    "extraResources": [
      {
        "from": "../",
        "to": "python-backend",
        "filter": [
          "app.py",
          "app_state.py",
          "run.py",
          "pyproject.toml",
          "config/**/*",
          "bot/**/*",
          "core/**/*",
          "db/**/*",
          "templates/**/*",
          "routes/**/*",
          "static/**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/tests/**",
          "!**/venv/**",
          "!**/.venv/**",
          "!**/node_modules/**",
          "!**/.git/**"
        ]
      },
      {
        "from": "python-runtime",
        "to": "python-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico"
    }
  }
}
