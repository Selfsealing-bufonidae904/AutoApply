\documentclass[10pt,a4paper]{article}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{helvet}
\renewcommand{\familydefault}{\sfdefault}
\usepackage[margin=0.5in]{geometry}
\usepackage{enumitem}
\usepackage{hyperref}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

\newcommand{\sectionheading}[1]{%
    \vspace{6pt}{\small\bfseries\uppercase{#1}}\vspace{2pt}\hrule\vspace{4pt}%
}

\begin{document}

% Header — compact single line
{\large\bfseries \VAR{name}} \hfill
{\small \VAR{email}
\BLOCK{if phone} $\cdot$ \VAR{phone}\BLOCK{endif}
\BLOCK{if location} $\cdot$ \VAR{location}\BLOCK{endif}
}
\vspace{2pt}\hrule\vspace{4pt}

% Summary
\BLOCK{if summary}
{\small \VAR{summary}}
\vspace{2pt}
\BLOCK{endif}

% Education
\BLOCK{if education}
\sectionheading{Education}
\BLOCK{for entry in education}
{\small\bfseries \VAR{entry.institution}}\BLOCK{if entry.location} \hfill {\small \VAR{entry.location}}\BLOCK{endif}\\*
{\small \VAR{entry.degree}}\BLOCK{if entry.dates} \hfill {\small\textit{\VAR{entry.dates}}}\BLOCK{endif}
\BLOCK{if not loop.last}\\[2pt]\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Skills
\BLOCK{if skills}
\sectionheading{Skills}
{\small
\BLOCK{for group in skills}
\textbf{\VAR{group.category}}: \VAR{group.entries}\BLOCK{if not loop.last}\\\BLOCK{endif}
\BLOCK{endfor}
}
\BLOCK{endif}

% Experience
\BLOCK{if experience}
\sectionheading{Experience}
\BLOCK{for comp in experience}
\BLOCK{for role in comp.roles}
{\small\bfseries \VAR{comp.company}}\BLOCK{if comp.location} \hfill {\small \VAR{comp.location}}\BLOCK{endif}\\*
{\small\textit{\VAR{role.title}}}\BLOCK{if role.dates} \hfill {\small\textit{\VAR{role.dates}}}\BLOCK{endif}
\begin{itemize}[leftmargin=1em,topsep=0pt,itemsep=0pt,parsep=0pt]
\BLOCK{for bullet in role.bullets}
    \item {\small \VAR{bullet}}
\BLOCK{endfor}
\end{itemize}
\BLOCK{endfor}
\BLOCK{endfor}
\BLOCK{endif}

% Projects
\BLOCK{if projects}
\sectionheading{Projects}
\BLOCK{for proj in projects}
\BLOCK{if proj.name}{\small\bfseries \VAR{proj.name}}\\*\BLOCK{endif}
\begin{itemize}[leftmargin=1em,topsep=0pt,itemsep=0pt,parsep=0pt]
\BLOCK{for bullet in proj.bullets}
    \item {\small \VAR{bullet}}
\BLOCK{endfor}
\end{itemize}
\BLOCK{endfor}
\BLOCK{endif}

% Certifications
\BLOCK{if certifications}
\sectionheading{Certifications}
{\small
\BLOCK{for entry in certifications}
\VAR{entry.text}\BLOCK{if not loop.last} $\cdot$ \BLOCK{endif}
\BLOCK{endfor}
}
\BLOCK{endif}

\end{document}
