\pagestyle{empty}
\setlength{\parindent}{0pt}

\titleformat{\section}{\large\bfseries\scshape}{}{0em}{}[\hrule]
\titlespacing{\section}{0pt}{14pt}{6pt}

\begin{document}

% Header
\begin{center}
    {\LARGE\bfseries\scshape \VAR{name}}\\[6pt]
    {\small
    \VAR{email}
    \BLOCK{if phone} \quad \VAR{phone}\BLOCK{endif}
    \BLOCK{if location} \quad \VAR{location}\BLOCK{endif}
    \BLOCK{if linkedin_url} \quad \href{\VAR{linkedin_url}}{\VAR{linkedin_url}}\BLOCK{endif}
    }
\end{center}
\vspace{6pt}

% Summary / Research Interests
\BLOCK{if summary}
\section{Research Interests}
\VAR{summary}
\BLOCK{endif}

% Education (first for academic CV)
\BLOCK{if education}
\section{Education}
\BLOCK{for entry in education}
\textbf{\VAR{entry.institution}}\BLOCK{if entry.location} \hfill \VAR{entry.location}\BLOCK{endif}\\
\VAR{entry.degree}\BLOCK{if entry.dates} \hfill \textit{\VAR{entry.dates}}\BLOCK{endif}
\BLOCK{if not loop.last}\vspace{6pt}\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Experience
\BLOCK{if experience}
\section{Professional Experience}
\BLOCK{for comp in experience}
\BLOCK{for role in comp.roles}
\textbf{\VAR{comp.company}}\BLOCK{if comp.location} \hfill \VAR{comp.location}\BLOCK{endif}\\
\textit{\VAR{role.title}}\BLOCK{if role.dates} \hfill \textit{\VAR{role.dates}}\BLOCK{endif}
\begin{itemize}[leftmargin=1.5em,topsep=0pt,itemsep=2pt]
\BLOCK{for bullet in role.bullets}
    \item \VAR{bullet}
\BLOCK{endfor}
\end{itemize}
\BLOCK{endfor}
\BLOCK{if not loop.last}\vspace{4pt}\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Projects / Publications
\BLOCK{if projects}
\section{Selected Projects}
\BLOCK{for proj in projects}
\BLOCK{if proj.name}\textbf{\VAR{proj.name}}\\\BLOCK{endif}
\begin{itemize}[leftmargin=1.5em,topsep=0pt,itemsep=2pt]
\BLOCK{for bullet in proj.bullets}
    \item \VAR{bullet}
\BLOCK{endfor}
\end{itemize}
\BLOCK{endfor}
\BLOCK{endif}

% Skills
\BLOCK{if skills}
\section{Technical Proficiencies}
\BLOCK{for group in skills}
\textbf{\VAR{group.category}}: \VAR{group.entries}\BLOCK{if not loop.last}\\[2pt]\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Certifications / Awards
\BLOCK{if certifications}
\section{Certifications \& Awards}
\BLOCK{for entry in certifications}
\VAR{entry.text}\BLOCK{if not loop.last}\\[2pt]\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

\end{document}
