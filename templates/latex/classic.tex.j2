\documentclass[11pt,a4paper]{article}
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{helvet}
\renewcommand{\familydefault}{\sfdefault}
\usepackage[margin=0.75in]{geometry}
\usepackage{enumitem}
\usepackage{titlesec}
\usepackage{hyperref}
\usepackage{xcolor}

\pagestyle{empty}
\setlength{\parindent}{0pt}

\titleformat{\section}{\large\bfseries\uppercase}{}{0em}{}[\titlerule]
\titlespacing{\section}{0pt}{12pt}{6pt}

\begin{document}

% Header
\begin{center}
    {\LARGE\bfseries \VAR{name}}\\[4pt]
    \VAR{email}
    \BLOCK{if phone} $\cdot$ \VAR{phone}\BLOCK{endif}
    \BLOCK{if location} $\cdot$ \VAR{location}\BLOCK{endif}
    \BLOCK{if linkedin_url} $\cdot$ \href{\VAR{linkedin_url}}{\VAR{linkedin_url}}\BLOCK{endif}
\end{center}

% Summary
\BLOCK{if summary}
\section{Summary}
\VAR{summary}
\BLOCK{endif}

% Education
\BLOCK{if education}
\section{Education}
\BLOCK{for entry in education}
\textbf{\VAR{entry.institution}}\BLOCK{if entry.location} \hfill \VAR{entry.location}\BLOCK{endif}\\
\VAR{entry.degree}\BLOCK{if entry.dates} \hfill \textit{\VAR{entry.dates}}\BLOCK{endif}
\BLOCK{if not loop.last}\\[6pt]\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Skills
\BLOCK{if skills}
\section{Skills}
\BLOCK{for group in skills}
\textbf{\VAR{group.category}}: \VAR{group.entries}\BLOCK{if not loop.last}\\[2pt]\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Experience
\BLOCK{if experience}
\section{Experience}
\BLOCK{for comp in experience}
\BLOCK{for role in comp.roles}
\textbf{\VAR{comp.company}}\BLOCK{if comp.location} \hfill \VAR{comp.location}\BLOCK{endif}\\
\textit{\VAR{role.title}}\BLOCK{if role.dates} \hfill \textit{\VAR{role.dates}}\BLOCK{endif}
\begin{itemize}[leftmargin=1.5em,topsep=0pt,itemsep=1pt]
\BLOCK{for bullet in role.bullets}
    \item \VAR{bullet}
\BLOCK{endfor}
\end{itemize}
\BLOCK{endfor}
\BLOCK{if not loop.last}\vspace{4pt}\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

% Projects
\BLOCK{if projects}
\section{Projects}
\BLOCK{for proj in projects}
\BLOCK{if proj.name}\textbf{\VAR{proj.name}}\\\BLOCK{endif}
\begin{itemize}[leftmargin=1.5em,topsep=0pt,itemsep=1pt]
\BLOCK{for bullet in proj.bullets}
    \item \VAR{bullet}
\BLOCK{endfor}
\end{itemize}
\BLOCK{endfor}
\BLOCK{endif}

% Certifications
\BLOCK{if certifications}
\section{Certifications}
\BLOCK{for entry in certifications}
\VAR{entry.text}\BLOCK{if not loop.last}\\[2pt]\BLOCK{endif}
\BLOCK{endfor}
\BLOCK{endif}

\end{document}
